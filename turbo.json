{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["NEXT_BUILD_DIR", "NODE_ENV"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        ".next.new/**",
        "!.next.new/cache/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate:types": {
      "cache": false
    }
  }
}
